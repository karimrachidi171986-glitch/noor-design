# --- Netlify & Production Config ---
NODE_ENV=production
JWT_SECRET=your_long_random_jwt_secret_here

# --- Authentication (Admin) ---
ADMIN_USERNAME=karim
ADMIN_PASSWORD_HASH=$2b$10$oZ6KJp7HLSSJpm0pGNfRQuvsEVjgBmNmgY1E0Ua.VHscM06lCeMma # For karimdoha@123

# --- Cloud Storage (CRITICAL for Netlify) ---
# Create a free account at Cloudinary.com
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# OR individual keys for server-side:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Frontend (Public) Unsigned Uploads:
VITE_CLOUDINARY_CLOUD_NAME=REPLACE_WITH_YOUR_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=noordesign_upload

# --- Payment Providers (Stripe) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# --- Payment Providers (PayPal) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox # Switch to 'live' for production

# --- Payment Providers (CMI) ---
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_MODE=sandbox
